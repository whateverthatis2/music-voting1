{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.py"
    },
    {
      "src": "/vote",
      "dest": "/api/vote.py"
    },
    {
      "src": "/results",
      "dest": "/api/results.py"
    },
    {
      "src": "/protocol",
      "dest": "/api/protocol.py"
    },
    {
      "src": "/vote-heuristic",
      "dest": "/api/vote_heuristic.py"
    },
    {
      "src": "/heuristic-votes",
      "dest": "/api/heuristic_votes.py"
    },
    {
      "src": "/rankings",
      "dest": "/api/rankings.py"
    },
    {
      "src": "/save-ranking",
      "dest": "/api/save_ranking.py"
    },
    {
      "src": "/ranking-count",
      "dest": "/api/ranking_count.py"
    },
    {
      "src": "/aggregated-rankings",
      "dest": "/api/aggregated_rankings.py"
    }
  ]
}
